{
	"name": "@ngockhoi96/ctc-vue",
	"version": "1.0.0",
	"license": "MIT",
	"type": "module",
	"private": false,
	"description": "Vue 3 composable for clipboard operations using @ngockhoi96/ctc — useCopyToClipboard as shallowRefs, SSR-safe",
	"keywords": [
		"clipboard",
		"vue",
		"vue3",
		"composable",
		"copy-to-clipboard",
		"typescript",
		"tree-shakeable",
		"ssr-safe"
	],
	"homepage": "https://github.com/anIcedAntFA/ctc/tree/master/packages/vue#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/anIcedAntFA/ctc.git",
		"directory": "packages/vue"
	},
	"sideEffects": false,
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsdown",
		"lint": "biome check",
		"lint:fix": "biome check --fix",
		"format": "biome format --write",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"size": "size-limit",
		"validate": "publint && attw --pack"
	},
	"files": [
		"dist"
	],
	"size-limit": [
		{
			"path": "dist/index.mjs",
			"limit": "2 KB"
		}
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"peerDependencies": {
		"@ngockhoi96/ctc": "workspace:*",
		"vue": ">=3.0.0 <4.0.0"
	},
	"devDependencies": {
		"@ngockhoi96/ctc": "workspace:*",
		"@arethetypeswrong/cli": "0.18.2",
		"@size-limit/file": "12.0.1",
		"@vitest/coverage-v8": "4.1.3",
		"@vue/test-utils": "^2.4.6",
		"jsdom": "^26.0.0",
		"publint": "0.3.18",
		"size-limit": "12.0.1",
		"tsdown": "0.21.7",
		"typescript": "6.0.2",
		"vitest": "4.1.3",
		"vue": "^3.5.0"
	},
	"exports": {
		".": {
			"types": {
				"import": "./dist/index.d.mts",
				"require": "./dist/index.d.cts"
			},
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./package.json": "./package.json"
	}
}
