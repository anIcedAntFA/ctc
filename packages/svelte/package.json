{
	"name": "@ngockhoi96/ctc-svelte",
	"version": "0.0.2",
	"license": "MIT",
	"type": "module",
	"private": false,
	"description": "Svelte action and reactive helpers for @ngockhoi96/ctc clipboard utilities",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/anIcedAntFA/ctc.git",
		"directory": "packages/svelte"
	},
	"sideEffects": false,
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsdown",
		"lint": "biome check",
		"lint:fix": "biome check --fix",
		"format": "biome format --write",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"size": "size-limit",
		"validate": "publint && attw --pack --profile node16"
	},
	"size-limit": [
		{
			"path": "dist/index.mjs",
			"limit": "2 KB"
		}
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"peerDependencies": {
		"@ngockhoi96/ctc": "workspace:*",
		"svelte": ">=4.0.0"
	},
	"devDependencies": {
		"@ngockhoi96/ctc": "workspace:*",
		"@arethetypeswrong/cli": "0.18.2",
		"@size-limit/file": "12.0.1",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@testing-library/svelte": "5.3.1",
		"@vitest/coverage-v8": "4.1.3",
		"jsdom": "^26.0.0",
		"publint": "0.3.18",
		"size-limit": "12.0.1",
		"svelte": "^5.55.3",
		"tsdown": "0.21.7",
		"typescript": "6.0.2",
		"vitest": "4.1.3"
	},
	"exports": {
		".": {
			"types": {
				"import": "./dist/index.d.mts",
				"require": "./dist/index.d.cts"
			},
			"svelte": "./dist/index.mjs",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./runes": {
			"types": {
				"import": "./dist/runes.d.mts",
				"require": "./dist/runes.d.cts"
			},
			"svelte": "./src/runes/use-copy-to-clipboard.svelte.ts",
			"import": "./dist/runes.mjs",
			"require": "./dist/runes.cjs"
		},
		"./stores": {
			"types": {
				"import": "./dist/stores.d.mts",
				"require": "./dist/stores.d.cts"
			},
			"svelte": "./dist/stores.mjs",
			"import": "./dist/stores.mjs",
			"require": "./dist/stores.cjs"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"src/runes"
	]
}
