{
	"compilerOptions": {
		"strict": true,
		"target": "ES2020",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"isolatedDeclarations": true,
		"declaration": true,
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"skipLibCheck": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "tests"]
}
